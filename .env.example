# .env.example – template for required environment variables
# Copy this file to .env and fill in real values

# Gemini API key (replace with your own)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Whether to use Gemini Enterprise (TRUE/FALSE)
GOOGLE_GENAI_USE_ENTERPRISE=FALSE

# Required to call POST /incidents (sent as the X-API-Key header).
# Generate one yourself, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=YOUR_API_KEY

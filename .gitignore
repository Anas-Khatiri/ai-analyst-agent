cat > .gitignore <<'EOF'
# --------------------------------------------------------------
#  Python / FastAPI project – clean .gitignore
# --------------------------------------------------------------

# --- Environment & secret files ------------------------------------------------
.env                # local environment variables (API keys, DB passwords, …)
.env.*              # any variant (e.g. .env.dev, .env.test, .env.production)
.env.example        # keep a template, but don’t track the real values

# --- Python byte‑code ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ------------------------------------------------------
.venv/
venv/
ENV/
env/
.conda/
conda-env/
.python-version

# --- Build / distribution ----------------------------------------------------
build/
dist/
*.egg-info/
*.egg
*.manifest
*.spec

# --- Packaging ---------------------------------------------------------------
*.wheel
*.whl

# --- Test / coverage ---------------------------------------------------------
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.pytest_cache/
.pytest_cache
.tox/
.mypy_cache/
ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json

# --- Documentation ------------------------------------------------------------
/site/                # MkDocs / Sphinx output
/docs/_build/

# --- IDE / editor files ------------------------------------------------------
.idea/
.vscode/
*.sublime-workspace
*.sublime-project
*.swp
*~
# macOS Finder files
.DS_Store

# --- Project‑specific generated artefacts ------------------------------------
logs/
tmp/
*.log

# --- CI / GitHub Actions ------------------------------------------------------
# .github/   # uncomment if you want to ignore *all* workflow files

# --- Additional folders you asked to exclude ------------------------------------
docs/
.agents/
.github/

# --------------------------------------------------------------
# End of .gitignore
# --------------------------------------------------------------
EOF
